{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": {
          "limit": 100,
          "matchAny": false,
          "tags": [],
          "type": "dashboard"
        },
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "Summary (selected range)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "noValue": "0",
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue"}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "round(sum(increase(microbus_llm_tokens_total{deployment=~\"$deployment\"}[$__range])))",
          "legendFormat": "Total tokens",
          "refId": "A"
        }
      ],
      "title": "Total Tokens",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "noValue": "0",
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue"}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "round(sum(increase(microbus_llm_tokens_total{deployment=~\"$deployment\", direction=\"input\"}[$__range])))",
          "legendFormat": "Input",
          "refId": "A"
        }
      ],
      "title": "Input Tokens",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "noValue": "0",
          "thresholds": {"mode": "absolute", "steps": [{"color": "orange"}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "round(sum(increase(microbus_llm_tokens_total{deployment=~\"$deployment\", direction=\"output\"}[$__range])))",
          "legendFormat": "Output",
          "refId": "A"
        }
      ],
      "title": "Output Tokens",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Fraction of input-side tokens served from the provider's prompt cache. Higher is cheaper.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.2},
              {"color": "green", "value": 0.5}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(microbus_llm_tokens_total{deployment=~\"$deployment\", direction=\"cacheRead\"}[$__range])) / clamp_min(sum(increase(microbus_llm_tokens_total{deployment=~\"$deployment\", direction=~\"input|cacheRead\"}[$__range])), 1)",
          "legendFormat": "Cache hit ratio",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 6,
      "panels": [],
      "title": "Tokens Over Time",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Token counts in the chosen interval, broken down by direction. Stacked.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "tokens",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "normal"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}]},
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "input"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]
          },
          {
            "matcher": {"id": "byName", "options": "output"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
          },
          {
            "matcher": {"id": "byName", "options": "cacheRead"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
          },
          {
            "matcher": {"id": "byName", "options": "cacheWrite"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]
          }
        ]
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "id": 7,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "round(sum by (direction) (increase(microbus_llm_tokens_total{deployment=~\"$deployment\"}[$interval])))",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ],
      "title": "Tokens by Direction",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Token counts in the chosen interval, broken down by provider hostname.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "tokens",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "id": 8,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "round(sum by (provider) (increase(microbus_llm_tokens_total{deployment=~\"$deployment\"}[$interval])))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "Tokens by Provider",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Token counts in the chosen interval, broken down by model. Useful for spotting expensive models in your mix.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "tokens",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 15},
      "id": 9,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "round(sum by (model) (increase(microbus_llm_tokens_total{deployment=~\"$deployment\"}[$interval])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Tokens by Model",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 10,
      "panels": [],
      "title": "Cache Performance",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Per-provider cache hit ratio over time. Tracks how effectively each provider's prompt cache is being utilized.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "stacking": {"group": "A", "mode": "none"}
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 25},
      "id": 11,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (provider) (increase(microbus_llm_tokens_total{deployment=~\"$deployment\", direction=\"cacheRead\"}[$interval])) / clamp_min(sum by (provider) (increase(microbus_llm_tokens_total{deployment=~\"$deployment\", direction=~\"input|cacheRead\"}[$interval])), 1)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio by Provider",
      "type": "timeseries"
    }
  ],
  "refresh": "",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["microbus", "llm"],
  "templating": {
    "list": [
      {
        "current": {"text": "default", "value": "default"},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {"text": "PROD", "value": "PROD"},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(microbus_llm_tokens_total, deployment)",
        "hide": 0,
        "includeAll": true,
        "label": "Deployment",
        "name": "deployment",
        "options": [],
        "query": {
          "query": "label_values(microbus_llm_tokens_total, deployment)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {"text": "1h", "value": "1h"},
        "description": "",
        "label": "Interval",
        "name": "interval",
        "options": [
          {"selected": false, "text": "1m", "value": "1m"},
          {"selected": false, "text": "5m", "value": "5m"},
          {"selected": false, "text": "15m", "value": "15m"},
          {"selected": false, "text": "30m", "value": "30m"},
          {"selected": true,  "text": "1h", "value": "1h"},
          {"selected": false, "text": "3h", "value": "3h"},
          {"selected": false, "text": "6h", "value": "6h"},
          {"selected": false, "text": "12h", "value": "12h"},
          {"selected": false, "text": "24h", "value": "24h"}
        ],
        "query": "1m,5m,15m,30m,1h,3h,6h,12h,24h",
        "type": "custom"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "LLM Overview",
  "uid": "microbus_llm",
  "version": 1
}
