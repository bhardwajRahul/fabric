graph LR
    classDef task fill:#32a7c1,color:#f4f2ef,stroke:#32a7c1
    classDef term fill:#e5f4f3,color:#434343,stroke:#32a7c1
    classDef note fill:none,stroke:none,color:#32a7c1,font-size:0.8em
    linkStyle default stroke:#32a7c1

    _title{{"per-element-pipeline"}}:::term -.-> _start
    t0["taskS"]:::task
    t1["taskH"]:::task
    t2["taskA"]:::task
    t3["taskB"]:::task
    t4["taskM"]:::task
    t4_reduce(("reduce")):::term
    t4_reduce --> t4
    t5["taskL"]:::task
    t5_reduce(("reduce")):::term
    t5_reduce --> t5
    t0 -->|"for each"| t1
    t1 --> t2
    t1 --> t3
    t2 --> t4_reduce
    t3 --> t4_reduce
    t4 --> t5_reduce
    _start(( )):::term --> t0
    t5 --> _end(( )):::term
