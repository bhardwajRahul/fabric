graph LR
    classDef task fill:#32a7c1,color:#f4f2ef,stroke:#434343
    classDef sub fill:#ed2e92,color:#f4f2ef,stroke:#434343
    classDef term fill:#e5f4f3,color:#434343,stroke:#434343

    _title{{"inner"}}:::term --> _start
    t3@{ shape: trap-t, label: "taskW" }
    _start(( )):::term --> t0["taskX"]:::task
    t0 --> t1["taskY"]:::task
    t0 --> t2["taskZ"]:::task
    t1 -->|"fan-in"| t3
    t2 -->|"fan-in"| t3
    t3 --> _end(( )):::term
    class t3 task
