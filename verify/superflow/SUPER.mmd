graph LR
    classDef task fill:#32a7c1,color:#f4f2ef,stroke:#32a7c1
    classDef term fill:#e5f4f3,color:#434343,stroke:#32a7c1
    classDef note fill:none,stroke:none,color:#32a7c1,font-size:0.8em
    linkStyle default stroke:#32a7c1

    _title{{"super"}}:::term -.-> _start
    t0["taskA"]:::task
    t1["taskB"]:::task
    t2["taskC"]:::task
    t3["taskD"]:::task
    t3_reduce(("reduce")):::term
    t3_reduce --> t3
    t3_when{"when"}:::term
    t4["taskE"]:::task
    t4_reduce(("reduce")):::term
    t4_reduce --> t4
    t5["taskZ"]:::task
    t6["errorHandler"]:::task
    t7["superSubCall"]:::task
    t0 --> t1
    t1 -->|"for each"| t2
    t2 --> t3_reduce
    t2 -->|"onError"| t6
    t6 --> t3_reduce
    t7 --> t4_reduce
    t4 -->|"goto"| t5
    t3 --> t3_when
    t3_when -->|"useSubgraph == true"| t7
    t3_when -->|"useSubgraph != true"| t4_reduce
    _start(( )):::term --> t0
    t4 --> _end(( )):::term
    t5 --> _end(( )):::term
