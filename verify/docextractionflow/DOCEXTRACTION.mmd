graph LR
    classDef task fill:#32a7c1,color:#f4f2ef,stroke:#32a7c1
    classDef term fill:#e5f4f3,color:#434343,stroke:#32a7c1
    classDef note fill:none,stroke:none,color:#32a7c1,font-size:0.8em
    linkStyle default stroke:#32a7c1

    _title{{"doc-extraction"}}:::term -.-> _start
    t0["scanPDF"]:::task
    t1["identifyChunks"]:::task
    t2["transcribeChunk"]:::task
    t3["joinPageTranscriptions"]:::task
    t3_reduce(("reduce")):::term
    t3_reduce --> t3
    t4["joinDocTranscriptions"]:::task
    t4_reduce(("reduce")):::term
    t4_reduce --> t4
    t0 -->|"for each"| t1
    t1 -->|"for each"| t2
    t2 --> t3_reduce
    t3 --> t4_reduce
    _start(( )):::term --> t0
    t4 --> _end(( )):::term
