    t4 --> t5_reduce
    t0 -->|"for each"| t2
    t0 --> t3
    t1 --> t5_reduce
    t2 --> t5_reduce
    t3 --> t5_reduce
    t5 -->|"goto"| t7
    t5 --> t6
    t6 -->|"goto"| t7
