    classDef term fill:#e5f4f3,color:#434343,stroke:#32a7c1
    classDef note fill:none,stroke:none,color:#32a7c1,font-size:0.8em
    linkStyle default stroke:#32a7c1

    _title{{"identity-verification"}}:::term -.-> _start
    t0["initIdentityVerification"]:::task
    t1["verifySSN"]:::task
    t2["verifyAddress"]:::task
    t3["verifyPhoneNumber"]:::task
    t4["identityDecision"]:::task
    t4_reduce(("reduce")):::term
    t4_reduce --> t4
    t0 --> t1
    t0 --> t2
    t0 --> t3
    t1 --> t4_reduce
    t2 --> t4_reduce
    t3 --> t4_reduce
    _start(( )):::term --> t0
    t4 --> _end(( )):::term
